# 애플리케이션 DB 접속 정보 (실제 값은 .env 에 복사해서 사용)
# 로컬에서 uv 로 앱을 실행할 때 사용하는 값 (docker-compose 의 db 서비스와 일치)
DATABASE_URL=mysql+aiomysql://sample:sample@localhost:3306/fastapi_sample

# MySQL 컨테이너 초기화용 (docker-compose 가 참조)
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=fastapi_sample
MYSQL_USER=sample
MYSQL_PASSWORD=sample
